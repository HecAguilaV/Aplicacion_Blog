<h1>Posts</h1>
<table>
  <thead>
    <tr>
      <th>Título</th>
      <th>Cuerpo</th>
      <th colspan="3"></th>
    </tr>
  </thead>
  <tbody>
    <% @posts.each do |post| %>
      <tr>
        <td><%= post.title %></td>
        <td><%= post.body %></td>
        <td><%= link_to 'Mostrar', post %></td>
        <td><%= link_to 'Editar', edit_post_path(post) %></td>
        <td><%= button_to 'Eliminar', post, method: :delete %></td>
      </tr>
    <% end %>
  </tbody>
</table>
<%= link_to 'Nuevo Post', new_post_path %>
