<h1>Usuarios</h1>
<br>
<% @users.each do |user| %>
  <div class="card">
    <h2><%= link_to user.full_name, user_path(user) %></h2>
    <p>Miembro desde <%= user.created_at.strftime("%B %Y") %></p>
    <div class="meta"><%= user.posts.count %> posts - <%= user.comments.count %> comentarios</div>
  </div>
<% end %>
