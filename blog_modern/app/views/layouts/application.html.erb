<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Blog RR - Rails 8</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', system-ui, sans-serif; background: linear-gradient(135deg, #0f0c29, #302b63, #24243e); color: #e0e0e0; min-height: 100vh; }
    nav { background: rgba(255,255,255,0.08); backdrop-filter: blur(10px); padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid rgba(255,255,255,0.1); }
    nav a { color: #a78bfa; text-decoration: none; font-weight: 600; margin: 0 0.5rem; }
    nav a:hover { color: #c4b5fd; }
    .logo { font-size: 1.4rem; font-weight: 800; background: linear-gradient(90deg, #a78bfa, #818cf8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .container { max-width: 900px; margin: 2rem auto; padding: 0 1rem; }
    .card { background: rgba(255,255,255,0.06); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 1.5rem; margin-bottom: 1.5rem; transition: transform 0.2s, box-shadow 0.2s; }
    .card:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(139, 92, 246, 0.15); }
    .card h2 { color: #c4b5fd; margin-bottom: 0.5rem; }
    .card h2 a { color: #c4b5fd; text-decoration: none; }
    .card p { color: #9ca3af; line-height: 1.6; }
    .meta { font-size: 0.85rem; color: #6b7280; margin-top: 0.5rem; }
    h1 { font-size: 2rem; margin-bottom: 1.5rem; background: linear-gradient(90deg, #a78bfa, #818cf8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .btn { display: inline-block; padding: 0.6rem 1.2rem; background: linear-gradient(135deg, #7c3aed, #6366f1); color: white; border: none; border-radius: 8px; text-decoration: none; font-weight: 600; cursor: pointer; transition: opacity 0.2s; }
    .btn:hover { opacity: 0.85; }
    .btn-sm { padding: 0.4rem 0.8rem; font-size: 0.85rem; }
    .btn-danger { background: linear-gradient(135deg, #dc2626, #ef4444); }
    .flash { padding: 1rem; border-radius: 8px; margin-bottom: 1rem; background: rgba(139, 92, 246, 0.2); border: 1px solid rgba(139, 92, 246, 0.3); }
    form label { display: block; margin: 0.8rem 0 0.3rem; color: #c4b5fd; font-weight: 600; }
    form input[type="text"], form textarea, form select { width: 100%; padding: 0.6rem; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 8px; color: #e0e0e0; font-size: 1rem; }
    form textarea { min-height: 120px; resize: vertical; }
    .comment { padding: 1rem; border-left: 3px solid #7c3aed; margin: 0.8rem 0; background: rgba(255,255,255,0.03); border-radius: 0 8px 8px 0; }
    .actions { display: flex; gap: 0.5rem; margin-top: 1rem; }
  </style>
</head>
<body>
  <nav>
    <span class="logo">Blog RR</span>
    <div>
      <%= link_to "Posts", posts_path %>
      <%= link_to "Usuarios", users_path %>
    </div>
  </nav>
  <div class="container">
    <% if notice %>
      <div class="flash"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div class="flash" style="background: rgba(220,38,38,0.2); border-color: rgba(220,38,38,0.3);"><%= alert %></div>
    <% end %>
    <%= yield %>
  </div>
</body>
</html>
